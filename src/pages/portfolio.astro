---
import { getCollection } from 'astro:content'

import PageHeader from '../components/PageHeader.astro'
import BaseLayout from '../layouts/BaseLayout.astro'

const projects = await getCollection('portfolio')
projects.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())

const formatDate = (date: Date) =>
  date.toLocaleDateString('pl-PL', { year: 'numeric', month: 'long' })
---

<BaseLayout
  title="Portfolio"
  description="Realizacje TomDevWeb — strony firmowe, sklepy internetowe, optymalizacja. Sprawdź wybrane projekty i efekty współpracy."
  locale="pl"
  alternateHref="/en/portfolio"
>
  <PageHeader
    label="&lt;portfolio /&gt;"
    title="Wybrane realizacje"
    description={`${projects.length} ukończonych projektów. Każdy z innym wyzwaniem, każdy z mierzalnym efektem.`}
  />

  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        projects.map((project) => {
          const slug = project.id.replace(/\.md$/, '')
          return (
            <li class="group flex flex-col rounded-xl border border-gray-100 transition-colors hover:border-gray-200 dark:border-gray-800 dark:hover:border-gray-700">
              <!-- Placeholder grafiki projektu -->
              <div class="flex h-44 items-center justify-center rounded-t-xl bg-gray-50 dark:bg-gray-900">
                <span class="font-mono text-2xl text-gray-200 dark:text-gray-700">&lt;/&gt;</span>
              </div>

              <div class="flex flex-1 flex-col gap-3 p-5">
                {project.data.featured && (
                  <span class="w-fit rounded-md bg-accent/10 px-2 py-0.5 font-mono text-xs text-accent">
                    wyróżniony
                  </span>
                )}

                <h2 class="font-semibold text-gray-900 dark:text-gray-100">
                  {project.data.title}
                </h2>

                <p class="flex-1 text-sm leading-relaxed text-gray-500 dark:text-gray-400">
                  {project.data.description}
                </p>

                <ul class="flex flex-wrap gap-1.5">
                  {project.data.tags.map((tag) => (
                    <li class="rounded-md bg-gray-50 px-2 py-0.5 font-mono text-xs text-gray-500 dark:bg-gray-900 dark:text-gray-400">
                      {tag}
                    </li>
                  ))}
                </ul>

                <div class="mt-1 flex items-center justify-between border-t border-gray-100 pt-3 dark:border-gray-800">
                  <span class="font-mono text-xs text-gray-400 dark:text-gray-500">
                    {formatDate(project.data.date)}
                  </span>
                  <a
                    href={`/portfolio/${slug}`}
                    class="text-sm font-medium text-accent transition-colors hover:text-accent-hover"
                  >
                    Czytaj więcej →
                  </a>
                </div>
              </div>
            </li>
          )
        })
      }
    </ul>

    <!-- CTA -->
    <div class="mt-16 text-center">
      <p class="mb-4 text-gray-500 dark:text-gray-400">
        Chcesz dołączyć do listy zadowolonych klientów?
      </p>
      <a
        href="/kontakt"
        class="inline-flex items-center rounded-lg bg-accent px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-accent-hover"
      >
        Zacznijmy projekt
      </a>
    </div>
  </section>
</BaseLayout>
