---
import PageHeader from '../../components/PageHeader.astro'
import BaseLayout from '../../layouts/BaseLayout.astro'

const contactDetails = [
  { label: 'Email', value: 'kontakt@tomdevweb.pl', href: 'mailto:kontakt@tomdevweb.pl', mono: true },
  { label: 'Phone', value: '+48 600 000 000', href: 'tel:+48600000000', mono: true },
  {
    label: 'Location',
    value: 'ul. Krakowska 62d, 32-090 Słomniki',
    hint: 'Remote — all of Poland',
    mono: false,
  },
]
---

<BaseLayout
  title="Contact"
  description="Get in touch with TomDevWeb — write or call. I reply within 24 hours."
  locale="en"
  alternateHref="/kontakt"
>
  <PageHeader
    label="&lt;contact /&gt;"
    title="Let's talk"
    description="Got a question, a project idea, or just want to say hi? Reach out — I'll reply within 24 hours."
  />

  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <div class="grid gap-12 lg:grid-cols-2">
      <div class="flex flex-col gap-8">
        <div class="flex items-center gap-4">
          <span class="font-mono text-sm text-accent">01.</span>
          <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100">Contact details</h2>
          <div class="h-px flex-1 bg-gray-100 dark:bg-gray-800"></div>
        </div>

        <ul class="flex flex-col gap-6 pl-8">
          {
            contactDetails.map(({ label, value, href, hint, mono }) => (
              <li class="flex flex-col gap-1">
                <span class="font-mono text-xs text-gray-400 dark:text-gray-500">{label}</span>
                {href ? (
                  <a
                    href={href}
                    class:list={[
                      'transition-colors hover:text-accent',
                      mono
                        ? 'font-mono text-sm text-gray-700 dark:text-gray-300'
                        : 'text-gray-700 dark:text-gray-300',
                    ]}
                  >
                    {value}
                  </a>
                ) : (
                  <span class:list={[mono ? 'font-mono text-sm text-gray-700 dark:text-gray-300' : 'text-gray-700 dark:text-gray-300']}>
                    {value}
                  </span>
                )}
                {hint && <span class="text-xs text-gray-400 dark:text-gray-500">{hint}</span>}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="flex flex-col gap-8">
        <div class="flex items-center gap-4">
          <span class="font-mono text-sm text-accent">02.</span>
          <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100">How it works</h2>
          <div class="h-px flex-1 bg-gray-100 dark:bg-gray-800"></div>
        </div>

        <ol class="flex flex-col gap-5 pl-8">
          {
            [
              { step: '01', text: 'You reach out with a short description of your project or question.' },
              { step: '02', text: "I reply within 24 hours and we schedule a quick call." },
              { step: '03', text: "We discuss the details and I prepare a no-obligation quote." },
              { step: '04', text: "We kick off — agree on a timeline and get to work." },
            ].map(({ step, text }) => (
              <li class="flex gap-4">
                <span class="mt-0.5 shrink-0 font-mono text-xs text-accent">{step}.</span>
                <span class="text-sm leading-relaxed text-gray-600 dark:text-gray-400">{text}</span>
              </li>
            ))
          }
        </ol>

        <div class="rounded-xl border border-gray-100 p-5 dark:border-gray-800 pl-8">
          <p class="mb-1 font-mono text-xs text-gray-400 dark:text-gray-500">availability</p>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Currently accepting new projects.<br />
            <span class="text-gray-400 dark:text-gray-500">Response time: within 24h on business days.</span>
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
