---
interface Props {
  label: string
  heading: string
  description: string
  buttonLabel: string
  buttonHref: string
}

const { label, heading, description, buttonLabel, buttonHref } = Astro.props
---

<section class="border-t border-gray-100 dark:border-gray-800">
  <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6">
    <div class="rounded-2xl bg-gray-50 px-8 py-14 text-center dark:bg-gray-900 sm:px-12">
      <span class="mb-4 inline-block font-mono text-sm text-accent">{label}</span>

      <h2 class="mb-4 text-3xl font-semibold tracking-tight text-gray-900 dark:text-gray-100 sm:text-4xl">
        {heading}
      </h2>

      <p class="mx-auto mb-8 max-w-md text-gray-500 dark:text-gray-400">
        {description}
      </p>

      <a
        href={buttonHref}
        class="inline-flex items-center rounded-lg bg-accent px-7 py-3 text-sm font-medium text-white transition-colors hover:bg-accent-hover"
      >
        {buttonLabel}
      </a>
    </div>
  </div>
</section>
