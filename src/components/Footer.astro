---
import { type Locale,ui } from '../i18n/index'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const currentYear = new Date().getFullYear()
const { footer } = ui[locale]
---

<footer class="mt-auto border-t border-gray-200 dark:border-gray-800">
  <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6">
    <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
      <p class="font-mono text-sm text-gray-500 dark:text-gray-400">
        © {currentYear} TomDevWeb — Tomasz Domagalski
      </p>
      <p class="text-xs text-gray-400 dark:text-gray-600">
        {footer.builtWith}{' '}
        <a
          href="https://astro.build"
          target="_blank"
          rel="noopener noreferrer"
          class="transition-colors hover:text-accent"
        >
          Astro
        </a>{' '}
        {footer.and}
      </p>
    </div>
  </div>
</footer>
