---
interface Props {
  label: string
  headingTop: string
  headingBottom: string
  headingAccent: string
  description: string
  primaryCta: { label: string; href: string }
  secondaryCta: { label: string; href: string }
}

const { label, headingTop, headingBottom, headingAccent, description, primaryCta, secondaryCta } =
  Astro.props
---

<section class="mx-auto max-w-6xl px-4 py-24 sm:px-6 lg:py-32">
  <div class="max-w-3xl">
    <span
      class="hero-animate mb-6 inline-block font-mono text-sm text-accent"
      style="animation-delay: 0ms"
    >
      {label}
    </span>

    <h1
      class="hero-animate mb-6 text-3xl font-semibold leading-tight tracking-tight text-gray-900 dark:text-gray-100 sm:text-5xl lg:text-6xl"
      style="animation-delay: 150ms"
    >
      {headingTop}<br />
      {headingBottom}&nbsp;<span class="text-accent">{headingAccent}</span>.
    </h1>

    <p
      class="hero-animate mb-10 max-w-xl text-base leading-relaxed text-gray-500 dark:text-gray-400 lg:text-lg"
      style="animation-delay: 300ms"
    >
      {description}
    </p>

    <div
      class="hero-animate flex flex-wrap gap-4"
      style="animation-delay: 450ms"
    >
      <a
        href={primaryCta.href}
        class="inline-flex min-h-[44px] items-center rounded-lg bg-accent px-6 py-3 text-sm font-medium text-white transition-all duration-200 hover:bg-accent-hover hover:shadow-md active:scale-[0.98]"
      >
        {primaryCta.label}
      </a>
      <a
        href={secondaryCta.href}
        class="inline-flex min-h-[44px] items-center rounded-lg border border-gray-200 px-6 py-3 text-sm font-medium text-gray-700 transition-all duration-200 hover:border-gray-300 hover:text-gray-900 hover:shadow-sm dark:border-gray-700 dark:text-gray-300 dark:hover:border-gray-600 dark:hover:text-gray-100"
      >
        {secondaryCta.label}
      </a>
    </div>
  </div>
</section>
