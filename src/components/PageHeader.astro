---
interface Props {
  label: string
  title: string
  description?: string
}

const { label, title, description } = Astro.props
---

<div class="border-b border-gray-100 dark:border-gray-800">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20">
    <span class="mb-3 inline-block font-mono text-sm text-accent">{label}</span>
    <h1 class="mb-4 text-3xl font-semibold tracking-tight text-gray-900 dark:text-gray-100 sm:text-4xl">
      {title}
    </h1>
    {
      description && (
        <p class="max-w-2xl text-lg leading-relaxed text-gray-500 dark:text-gray-400">
          {description}
        </p>
      )
    }
  </div>
</div>
