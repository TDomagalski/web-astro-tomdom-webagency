---
import { type Locale, type NavLink,ui } from '../i18n/index'

interface Props {
  locale: Locale
  links: NavLink[]
  alternateHref?: string
}

const { locale, links, alternateHref } = Astro.props
const currentPath = Astro.url.pathname
const { langToggle } = ui[locale]
---

<header class="sticky top-0 z-50 border-b border-gray-200 bg-white/80 backdrop-blur-sm dark:border-gray-800 dark:bg-gray-950/80">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6">
    <!-- Logo -->
    <a href={locale === 'pl' ? '/' : '/en/'} class="font-mono text-lg font-semibold tracking-tight text-gray-900 dark:text-gray-100">
      Tom<span class="text-accent">Dev</span>Web
    </a>

    <!-- Linki nawigacyjne — widoczne tylko na desktop -->
    <ul class="hidden items-center gap-6 md:flex">
      {
        links.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                'text-sm font-medium transition-colors hover:text-accent',
                currentPath === href ? 'text-accent' : 'text-gray-600 dark:text-gray-400',
              ]}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Prawa strona: przełącznik języka, motywu i hamburger -->
    <div class="flex items-center gap-2">
      <!-- Przełącznik języka -->
      {
        alternateHref && (
          <a
            href={alternateHref}
            aria-label={langToggle.label}
            class="flex h-9 items-center justify-center rounded-lg border border-gray-200 px-3 font-mono text-xs font-medium text-gray-600 transition-colors hover:border-gray-300 hover:text-gray-900 dark:border-gray-700 dark:text-gray-400 dark:hover:border-gray-600 dark:hover:text-gray-100"
          >
            {langToggle.short}
          </a>
        )
      }

      <!-- Przełącznik dark/light mode -->
      <button
        id="theme-toggle"
        aria-label="Przełącz motyw jasny/ciemny"
        class="flex h-9 w-9 items-center justify-center rounded-lg border border-gray-200 text-gray-600 transition-colors hover:border-gray-300 hover:text-gray-900 dark:border-gray-700 dark:text-gray-400 dark:hover:border-gray-600 dark:hover:text-gray-100"
      >
        <svg id="icon-sun" class="hidden h-4 w-4 dark:block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
        </svg>
        <svg id="icon-moon" class="block h-4 w-4 dark:hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3a7 7 0 009.79 9.79z" />
        </svg>
      </button>

      <!-- Hamburger — widoczny tylko na mobile -->
      <button
        id="mobile-menu-toggle"
        aria-label="Otwórz menu nawigacyjne"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="flex h-9 w-9 items-center justify-center rounded-lg border border-gray-200 text-gray-600 transition-colors hover:border-gray-300 hover:text-gray-900 dark:border-gray-700 dark:text-gray-400 dark:hover:border-gray-600 dark:hover:text-gray-100 md:hidden"
      >
        <svg id="icon-menu" class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" class="hidden h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-gray-100 dark:border-gray-800 md:hidden">
    <ul class="mx-auto flex max-w-6xl flex-col px-4 py-3 sm:px-6">
      {
        links.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                'block py-3 text-sm font-medium transition-colors hover:text-accent',
                currentPath === href ? 'text-accent' : 'text-gray-600 dark:text-gray-400',
              ]}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script is:inline>
  const themeToggle = document.getElementById('theme-toggle')
  themeToggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark')
    localStorage.setItem('theme', isDark ? 'dark' : 'light')
  })

  const menuToggle = document.getElementById('mobile-menu-toggle')
  const mobileMenu = document.getElementById('mobile-menu')
  const iconMenu = document.getElementById('icon-menu')
  const iconClose = document.getElementById('icon-close')

  menuToggle?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('hidden') === false
    menuToggle.setAttribute('aria-expanded', String(isOpen))
    iconMenu?.classList.toggle('hidden', isOpen)
    iconClose?.classList.toggle('hidden', !isOpen)
  })

  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden')
      menuToggle?.setAttribute('aria-expanded', 'false')
      iconMenu?.classList.remove('hidden')
      iconClose?.classList.add('hidden')
    })
  })
</script>
